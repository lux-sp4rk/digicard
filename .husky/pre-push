#!/bin/sh

# Get the current branch name
current_branch=$(git symbolic-ref --short HEAD)

# Check if pushing to main branch
if [ "$current_branch" = "main" ]; then
  echo "❌ ERROR: Direct push to main branch is not allowed!"
  echo "Please create a feature branch and push that instead."
  echo ""
  echo "To create a new branch:"
  echo "  git checkout -b your-branch-name"
  echo ""
  exit 1
fi

# Run tests before push
echo "Running tests before push..."
pnpm run test
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo ""
  echo "❌ TESTS FAILED — fix failures before pushing"
  echo "   You can still force push with: git push --no-verify"
  echo "   But CI will likely fail and your branch will be broken."
  exit 1
fi

echo "✅ Tests passed"
