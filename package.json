{
  "name": "digicard",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch-content": "tsx scripts/fetch-content.ts",
    "prebuild": "npm run fetch-content",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --run --coverage",
    "test:coverage:watch": "vitest --watch --coverage",
    "test:safe": "node scripts/test-with-cleanup.js --run",
    "test:coverage:safe": "node scripts/test-with-cleanup.js --run --coverage",
    "test:ui:safe": "node scripts/test-with-cleanup.js --ui",
    "setup": "node scripts/setup.js",
    "test:cleanup": "pkill -f vitest || true",
    "dev:seed-data": "node scripts/seed-dev-data.js"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "^16.1.6",
    "@contentful/rich-text-types": "^17.2.5",
    "@tailwindcss/typography": "^0.5.16",
    "clsx": "^2.1.1",
    "contentful": "^11.7.7",
    "netlify-cli": "^23.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.0.1",
    "react-typed": "^2.0.12"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@contentful/rich-text-html-renderer": "^17.2.2",
    "@eslint/js": "^8.57.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitest/coverage-v8": "^3.2.4",
    "astro": "^5.18.1",
    "autoprefixer": "^10.4.16",
    "dotenv": "^16.6.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "imagemin-mozjpeg": "^10.0.0",
    "imagemin-pngquant": "^10.0.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "postcss": "^8.4.32",
    "postcss-modules": "^6.0.1",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-imagemin": "^0.6.1",
    "vitest": "^3.2.4"
  }
}
