---
import Layout from '../layouts/Layout.astro';
import ThemeSwitcher from '../islands/ThemeSwitcher.astro';
import TabNav from '../islands/TabNav.astro';
import FeaturedContentWrapper from '../islands/FeaturedContentWrapper.jsx';
import { loadContent, getProjects, getServices, getSkills, getProfile, getSettings } from '../data/loader';

const data = await loadContent();
const projects = getProjects(data);
const services = getServices(data);
const skills = getSkills(data);
const profile = getProfile(data);
const settings = getSettings(data);

const tabs = [
  { id: 'work', label: 'Work' },
  { id: 'services', label: 'Services' },
  { id: 'skills', label: 'Skills' },
];

// Normalize profile image URL
const profileImage = profile.profileImage?.startsWith('//')
  ? `https:${profile.profileImage}`
  : profile.profileImage || '/assets/avatar.jpg';

// Helper to extract text from rich text or return plain text
function descText(desc: any): string {
  if (typeof desc === 'string') return desc;
  if (desc?.nodeType === 'document') {
    // Simple plain-text extraction from Contentful rich text
    return desc.content?.map((block: any) =>
      block.content?.map((inline: any) => inline.value).join('')
    ).join('\n\n') || '';
  }
  return String(desc || '');
}

const socialLinks = settings.socialLinks || [];
---

<Layout>
  <div class="max-w-3xl mx-auto px-4 md:px-8 py-8 md:py-16">
    <div class="relative">
      {/* Header */}
      <header class="flex justify-end mb-5">
        <div class="relative text-right">
          <ThemeSwitcher />
        </div>
      </header>

      <main class="bg-white dark:bg-dracula-currentLine rounded-xl overflow-hidden mb-8 md:mb-12 matrix:bg-matrix-terminal matrix:border matrix:border-matrix-glow/30 web2:bg-web2-background web2:border-web2-border xmas:bg-xmas-cardBg xmas:border-xmas-gold/50 xmas:border catppuccin:bg-catppuccin-base catppuccin:text-catppuccin-text catppuccin:border catppuccin:border-catppuccin-surface flexoki:bg-flexoki-base flexoki:text-flexoki-text flexoki:border flexoki:border-flexoki-surface rosepine:bg-rosepine-base rosepine:text-rosepine-text rosepine:border rosepine:border-rosepine-rose/30">
        <TabNav tabs={tabs} defaultTab="work" />

        {/* Profile */}
        <section class="px-5 py-8 text-center">
          <div class="w-36 h-36 mx-auto mb-5">
            <img
              src={profileImage}
              alt={`${profile.name} avatar`}
              class="w-full h-full object-cover rounded-full"
            />
          </div>
          <h1 class="text-2xl font-heading font-bold tracking-tight mb-1">{profile.name}</h1>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{profile.title}</p>
          {profile.location && (
            <p class="text-xs text-gray-500 dark:text-gray-500 flex items-center justify-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"/></svg>
              {profile.location}
            </p>
          )}
          <div class="text-sm leading-relaxed max-w-xl mx-auto mt-4 text-gray-700 dark:text-gray-300">
            {profile.bio}
          </div>
        </section>

        {/* Work Tab */}
        <div data-tab-panel="work" class="hidden">
          {/* FeaturedContent fetches Substack / YouTube / Instagram / SoundCloud at runtime */}
          <FeaturedContentWrapper client:load />

          <section class="px-4 md:px-8 py-8">
            <h2 class="text-lg font-bold mb-6 tracking-tight">Projects</h2>
            <div class="max-w-4xl mx-auto space-y-0">
              {projects.map((project, index) => {
                const isEven = index % 2 === 0;
                const imageSrc = project.imgWide || project.imgNormal || '/assets/RDTBanner.png';
                return (
                  <article class={`grid gap-4 md:gap-8 md:grid-cols-2 items-center py-8 ${!isEven ? 'md:direction-rtl' : ''}`}>
                    <div class={`relative overflow-hidden aspect-[16/10] ${isEven ? 'md:order-1' : 'md:order-2'}`}>
                      <img src={imageSrc} alt={project.alt} class="w-full h-full object-cover" />
                    </div>
                    <div class={`flex flex-col ${isEven ? 'md:order-2 md:pl-4' : 'md:order-1 md:pr-4 md:text-right md:items-end'}`}>
                      <div class={`flex items-center gap-3 mb-3 ${!isEven ? 'md:flex-row-reverse' : ''}`}>
                        <h3 class="text-xl md:text-2xl font-heading font-bold tracking-tight">{project.title}</h3>
                      </div>
                      <div class="mb-6 leading-relaxed text-sm text-gray-700 dark:text-gray-300">
                        {descText(project.description)}
                      </div>
                      <a
                        href={project.link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 text-sm font-medium tracking-wide text-blue-600 hover:text-blue-500"
                      >
                        <span>View Project</span>
                        <span>→</span>
                      </a>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        </div>

        {/* Services Tab */}
        <div data-tab-panel="services" class="hidden">
          <section class="p-5">
            <h2 class="text-lg font-bold mb-6 tracking-tight">Services</h2>
            <div class="space-y-1">
              {services.map((service, index) => (
                <div class={`group relative py-6 px-2 ${index !== services.length - 1 ? 'border-b border-gray-200 dark:border-gray-700' : ''} ${index % 2 === 1 ? 'md:pl-12' : ''}`}>
                  <div class="flex items-start gap-4 md:gap-6">
                    <div class="flex-shrink-0 mt-1 opacity-70">
                      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-lg font-bold mb-1">{service.title}</h3>
                      {service.subtitle && <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">{service.subtitle}</p>}
                      <div class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                        {descText(service.description)}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-8 text-center">
              <h3 class="text-lg font-bold mb-3">Let's build something.</h3>
              <a
                href="https://linkedin.com/in/luhsprwhk"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-500 transition-colors"
              >
                Connect on LinkedIn
              </a>
            </div>
          </section>
        </div>

        {/* Skills Tab */}
        <div data-tab-panel="skills" class="hidden">
          <section class="p-5">
            <h2 class="text-lg font-bold mb-6 tracking-tight">Skills</h2>
            <div class="space-y-1">
              {skills.map((skill, index) => (
                <div class={`group relative py-6 px-2 ${index !== skills.length - 1 ? 'border-b border-gray-200 dark:border-gray-700' : ''} ${index % 2 === 1 ? 'md:pl-12' : ''}`}>
                  <div class="flex items-start gap-4 md:gap-6">
                    <div class="flex-shrink-0 mt-1 opacity-70">
                      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="10" />
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="text-lg font-bold mb-1">{skill.title}</h3>
                      {skill.subtitle && <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">{skill.subtitle}</p>}
                      <div class="text-sm leading-relaxed text-gray-700 dark:text-gray-300">
                        {descText(skill.description)}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="mt-8 text-center">
              <h3 class="text-lg font-bold mb-3">Want to leverage these skills for your project?</h3>
              <a
                href="mailto:ulises@luxspark.com"
                class="inline-block px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-500 transition-colors"
              >
                Let's Talk
              </a>
            </div>
          </section>
        </div>
      </main>

      {/* Footer */}
      <footer class="text-center pb-5 px-4 text-sm relative text-gray-600 dark:text-gray-400">
        <div class="flex justify-center gap-4 mb-4">
          {socialLinks.map(link => (
            <a
              key={link.id}
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.name}
              class="opacity-60 hover:opacity-100 transition-opacity"
            >
              <span class="sr-only">{link.name}</span>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <rect width="20" height="20" x="2" y="2" rx="4" />
              </svg>
            </a>
          ))}
        </div>
        <div class="mt-2">
          <span class="group relative inline-block opacity-40 hover:opacity-80 transition-opacity cursor-pointer">
            <svg class="inline-block w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5z" />
            </svg>
            <span class="absolute hidden group-hover:block bg-gray-800 text-white text-xs rounded p-2 -mt-2 -translate-y-full -translate-x-1/2 left-1/2 whitespace-nowrap z-10">
              console.log("Open sesame")
            </span>
          </span>
        </div>
      </footer>
    </div>
  </div>
</Layout>