---
export interface Props {
  title?: string;
}

const { title = "Luh Sprwhk — Agentic Engineer & Creative Technologist" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" data-theme="catppuccin">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Agentic Engineer & Creative Technologist — building autonomous systems and creative tools." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Inter:wght@400;500;600&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      // Theme initializer — runs before anything else to prevent flash
      (function() {
        const themes = ['dark','github','matrix','light','web2','xmas','catppuccin','flexoki','dracula','csszen','rosepine'];
        const month = new Date().getMonth();
        const isDecember = month === 11;
        let theme = isDecember ? 'xmas' : (sessionStorage.getItem('theme') || 'catppuccin');
        if (['github','dracula','csszen','dark','light','rosepine'].includes(theme)) theme = 'catppuccin';
        document.documentElement.classList.add(theme);
        document.documentElement.setAttribute('data-theme', theme);
        if (theme === 'matrix') document.body?.classList.add('matrix-bg');
      })();
    </script>
  </head>
  <body class="font-body bg-github-bgGray text-github-text transition-colors dark:bg-dracula-background dark:text-dracula-foreground matrix:bg-matrix-background matrix:text-matrix-text xmas:bg-xmas-background xmas:text-xmas-text catppuccin:bg-catppuccin-crust catppuccin:text-catppuccin-text flexoki:bg-flexoki-crust flexoki:text-flexoki-text">
    <slot />
  </body>
</html>
